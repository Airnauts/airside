# Copy to .env.local (auto-loaded by Next.js), then run `pnpm dev`.
#
#   cp .env.example .env.local

# MongoDB connection string. Matches the local container in docker-compose.yml
# (`docker compose up -d`). The database name comes from the path ("comments").
# Leave unset to use ephemeral in-memory persistence instead.
MONGODB_URI="mongodb://localhost:27017/comments"

# Optional: Vercel Blob token for upload storage in production. When unset,
# uploads are written to public/uploads/ on the local filesystem.
# BLOB_READ_WRITE_TOKEN=

# Optional: Resend email notifications. When RESEND_API_KEY is set, a reply to a
# thread emails the thread's other participants. The recipient is derived from
# the thread (NOT a fixed address), so email only fires on a reply, never on a
# new thread. RESEND_FROM is the sender; without a verified domain leave it as
# the default below — Resend's sandbox then only delivers to your own Resend
# signup address, so make the first comment as that address to receive one.
# RESEND_API_KEY=re_xxx
# RESEND_FROM="onboarding@resend.dev"
