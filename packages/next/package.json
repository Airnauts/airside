{
  "name": "@airnauts/airside-integration-next",
  "version": "0.8.2",
  "description": "Next.js App and Pages Router integration for the Airnauts commenting tool server.",
  "keywords": [
    "comments",
    "commenting",
    "annotations",
    "feedback",
    "airnauts",
    "next",
    "nextjs"
  ],
  "license": "MIT",
  "author": "Airnauts",
  "homepage": "https://github.com/Airnauts/airside#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Airnauts/airside.git",
    "directory": "packages/next"
  },
  "bugs": {
    "url": "https://github.com/Airnauts/airside/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsc --build --force",
    "typecheck": "tsc --build",
    "test": "vitest run"
  },
  "dependencies": {
    "@airnauts/airside-server": "workspace:^"
  },
  "devDependencies": {
    "@airnauts/airside-adapter-memory": "workspace:*",
    "@airnauts/airside-core": "workspace:*",
    "@airnauts/airside-test-support": "workspace:*"
  }
}
