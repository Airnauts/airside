{
  "name": "@airnauts/airside-adapter-mongo",
  "version": "0.8.2",
  "description": "MongoDB repository adapter for the Airnauts commenting tool server.",
  "keywords": [
    "comments",
    "commenting",
    "annotations",
    "feedback",
    "airnauts",
    "mongodb",
    "adapter"
  ],
  "license": "MIT",
  "author": "Airnauts",
  "homepage": "https://github.com/Airnauts/airside#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Airnauts/airside.git",
    "directory": "packages/adapter-mongo"
  },
  "bugs": {
    "url": "https://github.com/Airnauts/airside/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsc --build --force",
    "typecheck": "tsc --build",
    "test": "vitest run"
  },
  "dependencies": {
    "@airnauts/airside-core": "workspace:^",
    "@airnauts/airside-server": "workspace:^",
    "mongodb": "^6.12.0"
  },
  "devDependencies": {
    "@airnauts/airside-integration-next": "workspace:*",
    "@airnauts/airside-test-support": "workspace:*",
    "mongodb-memory-server": "^10.1.2"
  }
}
