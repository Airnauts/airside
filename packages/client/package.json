{
  "name": "@comments/client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc --build",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "size": "size-limit"
  },
  "dependencies": {
    "@comments/core": "workspace:*"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.6",
    "jsdom": "^26.0.0",
    "size-limit": "^11.1.6"
  },
  "size-limit": [
    {
      "name": "@comments/client (esm, brotli)",
      "path": "dist/index.js",
      "limit": "10 kB"
    }
  ]
}
