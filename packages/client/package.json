{
  "name": "@airnauts/airside-client",
  "version": "0.9.0",
  "description": "Embeddable, self-contained commenting widget for the Airnauts commenting tool.",
  "keywords": [
    "comments",
    "commenting",
    "annotations",
    "feedback",
    "airnauts",
    "widget",
    "react"
  ],
  "license": "MIT",
  "author": "Airnauts",
  "homepage": "https://github.com/Airnauts/airside#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Airnauts/airside.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/Airnauts/airside/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:css": "node scripts/build-css.mjs",
    "build": "pnpm build:css && rm -rf dist && tsup && tsc --build --force",
    "typecheck": "tsc --build",
    "test": "pnpm build:css && vitest run",
    "size": "size-limit"
  },
  "dependencies": {
    "@airnauts/airside-core": "workspace:^",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-popover": "^1.1.6",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@airnauts/airside-adapter-memory": "workspace:*",
    "@airnauts/airside-server": "workspace:*",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@tailwindcss/cli": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "size-limit": "^11.1.6",
    "tailwindcss": "^4.0.0"
  },
  "size-limit": [
    {
      "name": "@airnauts/airside-client (esm, brotli)",
      "path": "dist/index.js",
      "limit": "300 kB"
    }
  ]
}
